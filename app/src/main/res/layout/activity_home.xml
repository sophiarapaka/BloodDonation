<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <!-- Button 1: Find Donation Centers -->
    <Button
        android:id="@+id/btnFindCenters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Find Donation Centers"
        android:textSize="18sp"
        android:padding="12dp"
        android:backgroundTint="@android:color/holo_red_dark"
        android:textColor="@android:color/white"
        android:elevation="4dp"
        android:layout_margin="8dp"/>

    <!-- Button 2: Check Eligibility -->
    <Button
        android:id="@+id/btnCheckEligibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Check Eligibility"
        android:textSize="18sp"
        android:padding="12dp"
        android:backgroundTint="@android:color/holo_red_dark"
        android:textColor="@android:color/white"
        android:elevation="4dp"
        android:layout_margin="8dp"/>

    <!-- Button 3: View Donation History -->
    <Button
        android:id="@+id/btnDonationHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Donation History"
        android:textSize="18sp"
        android:padding="12dp"
        android:backgroundTint="@android:color/holo_red_dark"
        android:textColor="@android:color/white"
        android:elevation="4dp"
        android:layout_margin="8dp"/>

    <!-- Button 4: Donation Tips -->
    <Button
        android:id="@+id/btnDonationTips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Donation Tips"
        android:textSize="18sp"
        android:padding="12dp"
        android:backgroundTint="@android:color/holo_red_dark"
        android:textColor="@android:color/white"
        android:elevation="4dp"
        android:layout_margin="8dp"/>
</LinearLayout>
